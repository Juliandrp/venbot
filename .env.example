# ============================================================
# App
# ============================================================
SECRET_KEY=change-me-to-a-random-256-bit-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ENVIRONMENT=development   # development | production

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql+asyncpg://venbot:venbot_pass@postgres:5432/venbot_db
SYNC_DATABASE_URL=postgresql://venbot:venbot_pass@postgres:5432/venbot_db

# ============================================================
# Redis / Celery
# ============================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================================
# Encryption key for tenant secrets (Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ============================================================
ENCRYPTION_KEY=your-fernet-key-here

# ============================================================
# Platform-level AI keys (tenants can override in settings)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ============================================================
# Super-admin credentials (seeded on first run)
# ============================================================
SUPERADMIN_EMAIL=admin@venbot.io
SUPERADMIN_PASSWORD=change-me-immediately

# ============================================================
# App URL (used for webhooks, email links)
# ============================================================
APP_BASE_URL=https://yourdomain.com
