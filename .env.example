# ============================================================
# App
# ============================================================
SECRET_KEY=change-me-to-a-random-256-bit-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ENVIRONMENT=development   # development | production
APP_BASE_URL=http://localhost:8000

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql+asyncpg://venbot:venbot_pass@postgres:5432/venbot_db
SYNC_DATABASE_URL=postgresql://venbot:venbot_pass@postgres:5432/venbot_db

# ============================================================
# Redis / Celery
# ============================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================================
# Encryption key for tenant secrets (Fernet)
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ============================================================
ENCRYPTION_KEY=your-fernet-key-here

# ============================================================
# Platform-level AI keys (tenants can override in settings)
# ============================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
KLING_API_KEY=
HIGGSFIELD_API_KEY=

# ============================================================
# Super-admin credentials (seeded on first run)
# ============================================================
SUPERADMIN_EMAIL=admin@venbot.io
SUPERADMIN_PASSWORD=change-this-password

# ============================================================
# Storage (almacenamiento de imágenes/videos generados)
# ============================================================
# "local" = disco del contenedor (volumen persistente en Coolify)
# "s3"    = bucket S3-compatible (AWS S3, Cloudflare R2, MinIO)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/app/media
STORAGE_LOCAL_BASE_URL=/media

# Solo si STORAGE_BACKEND=s3
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1
S3_PUBLIC_BASE_URL=

# ============================================================
# Pagos (opcional — déjalo vacío para activar planes manualmente)
# ============================================================
# "" = sin pasarela | "stripe" | "mercadopago"
PAYMENT_PROVIDER=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# ============================================================
# Flower (monitoreo Celery)
# ============================================================
FLOWER_USER=admin
FLOWER_PASSWORD=change-this-password
